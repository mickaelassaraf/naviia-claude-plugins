{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_form_gate.py\" prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "prepare_two_pager|prepare_qa",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_form_gate.py\" pretool"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_form_gate.py\" pretool-bash"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_form_gate.py\" pretool-task"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_validate_section.py\""
          }
        ]
      },
      {
        "matcher": "render_two_pager_pdf|render_qa_docx|render_im_docx",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_form_gate.py\" posttool"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_form_gate.py\" posttool-bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/two-pager/scripts/hook_form_gate.py\" stop"
          }
        ]
      }
    ]
  }
}